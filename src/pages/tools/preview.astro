---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Print preview — Oriz Print" description="Paste text or HTML and see exactly how it lays out on letter/A4 before you print. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Print preview</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Paste text or HTML and see how it lays out on a real paper size before you print. Adjust paper, margin, and font, then send to print.</p>

    <div class="controls">
      <label>Paper
        <select id="paper">
          <option value="A4">A4 (210 x 297 mm)</option>
          <option value="LETTER">Letter (8.5 x 11 in)</option>
          <option value="A5">A5 (148 x 210 mm)</option>
        </select>
      </label>
      <label>Orientation
        <select id="orient">
          <option value="P">Portrait</option>
          <option value="L">Landscape</option>
        </select>
      </label>
      <label>Margin (mm) <input id="margin" type="number" min="0" max="40" value="15" /></label>
      <label>Font size <input id="fs" type="number" min="8" max="32" value="12" /></label>
      <label>Family
        <select id="fam">
          <option value="serif">Serif (Fraunces)</option>
          <option value="sans" selected>Sans (Inter)</option>
          <option value="mono">Monospace</option>
        </select>
      </label>
      <label class="chk"><input id="html" type="checkbox" /> input is HTML</label>
    </div>

    <label class="block">Content
      <textarea id="src" rows="8"></textarea>
    </label>

    <p id="err" class="err mono" hidden></p>

    <div class="actions">
      <button id="print" class="btn btn-primary">Print</button>
    </div>

    <div id="frame" class="frame" aria-live="polite">
      <div id="page" class="page"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  label.chk { flex-direction: row; align-items: center; gap: 0.4rem; }
  label.block { display: block; margin-bottom: 1rem; }
  input, select, textarea {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  textarea { width: 100%; resize: vertical; font-family: var(--font-mono); }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .actions { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .frame { background: #eee; padding: 1rem; display: flex; justify-content: center; }
  .page { background: #fff; color: #15140f; box-shadow: 0 2px 12px rgba(0,0,0,0.12); overflow: auto; }
  .page.serif { font-family: 'Fraunces', 'Crimson Pro', Georgia, serif; }
  .page.sans { font-family: 'Inter Tight', Inter, system-ui, sans-serif; }
  .page.mono { font-family: 'IBM Plex Mono', ui-monospace, monospace; }
  @media print {
    .back, .status, .lede, .controls, .err, .actions, header.site, footer.site, .oriz-sidebar, label.block { display: none !important; }
    .h1 { display: none; }
    .frame { background: none; padding: 0; }
    .page { box-shadow: none; width: auto !important; height: auto !important; padding: 0 !important; }
    @page { margin: 0; }
  }
</style>

<script>
  const paperEl = document.getElementById('paper') as HTMLSelectElement;
  const orientEl = document.getElementById('orient') as HTMLSelectElement;
  const marginEl = document.getElementById('margin') as HTMLInputElement;
  const fsEl = document.getElementById('fs') as HTMLInputElement;
  const famEl = document.getElementById('fam') as HTMLSelectElement;
  const htmlEl = document.getElementById('html') as HTMLInputElement;
  const srcEl = document.getElementById('src') as HTMLTextAreaElement;
  const page = document.getElementById('page') as HTMLElement;
  const err = document.getElementById('err') as HTMLElement;

  const SIZES_MM: Record<string, [number, number]> = {
    A4: [210, 297],
    LETTER: [215.9, 279.4],
    A5: [148, 210],
  };

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c] as string));
  }
  function sanitizeHtml(s: string): string {
    // Strip <script> and inline event handlers. Allow most other tags.
    let cleaned = s.replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '');
    cleaned = cleaned.replace(/\son\w+\s*=\s*"[^"]*"/gi, '');
    cleaned = cleaned.replace(/\son\w+\s*=\s*'[^']*'/gi, '');
    cleaned = cleaned.replace(/javascript:/gi, '');
    return cleaned;
  }

  function render() {
    try {
      err.hidden = true;
      let [w, h] = SIZES_MM[paperEl.value] || SIZES_MM.A4;
      if (orientEl.value === 'L') [w, h] = [h, w];
      const mmToPx = 96 / 25.4;
      const margin = Math.max(0, parseFloat(marginEl.value) || 0);
      const fs = Math.max(8, Math.min(32, parseInt(fsEl.value, 10) || 12));
      page.style.width = (w * mmToPx) + 'px';
      page.style.minHeight = (h * mmToPx) + 'px';
      page.style.padding = (margin * mmToPx) + 'px';
      page.style.fontSize = fs + 'pt';
      page.className = 'page ' + famEl.value;
      const raw = srcEl.value;
      if (htmlEl.checked) page.innerHTML = sanitizeHtml(raw);
      else page.innerHTML = raw.split(/\n\s*\n/).map(p => `<p>${escapeHtml(p).replace(/\n/g,'<br>')}</p>`).join('');
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
    }
  }

  [paperEl, orientEl, marginEl, fsEl, famEl, htmlEl, srcEl].forEach(el =>
    el.addEventListener('input', render)
  );
  document.getElementById('print')!.addEventListener('click', () => window.print());

  srcEl.value = 'The quick brown fox jumps over the lazy dog.\n\nThis is print preview — paste your content, pick paper and margins, and see exactly how it lays out before you hit print. Toggle "input is HTML" to render inline markup.';
  render();
</script>
