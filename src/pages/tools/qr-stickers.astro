---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="QR sticker sheet — Oriz Print" description="Generate a sheet of QR-code stickers from a list of URLs or labels. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">QR sticker sheet</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">One URL or text per line. The tool builds a sticker sheet of QR codes (each with an optional caption) sized for letter or A4. Runs entirely in your browser.</p>

    <div class="controls">
      <label>Columns <input id="cols" type="number" min="1" max="10" value="4" /></label>
      <label>Rows <input id="rows" type="number" min="1" max="14" value="6" /></label>
      <label>Paper
        <select id="paper">
          <option value="A4">A4</option>
          <option value="LETTER">Letter</option>
        </select>
      </label>
      <label class="chk"><input id="caption" type="checkbox" checked /> show caption</label>
      <label class="chk"><input id="repeat" type="checkbox" /> repeat first to fill</label>
    </div>

    <label class="block">URLs or text (one per line, optional `|caption`)
      <textarea id="src" rows="8" placeholder="https://oriz.in&#10;https://print.oriz.in|Print tools"></textarea>
    </label>

    <p id="err" class="err mono" hidden></p>

    <div class="actions">
      <button id="render" class="btn btn-primary">Render</button>
      <button id="print" class="btn">Print</button>
    </div>

    <div id="sheet" class="sheet" aria-live="polite"></div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  label.chk { flex-direction: row; align-items: center; gap: 0.4rem; }
  label.block { display: block; margin-bottom: 1rem; }
  input, select, textarea {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  textarea { width: 100%; resize: vertical; }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .actions { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .sheet { display: grid; gap: 0; background: #fff; padding: 0; margin: 0 auto; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
  .cell { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0.4rem; gap: 0.25rem; outline: 1px dashed #ddd; }
  .cell canvas { display: block; image-rendering: pixelated; max-width: 100%; height: auto; }
  .cell .cap { font-family: Inter, system-ui, sans-serif; font-size: 0.65rem; color: #15140f; text-align: center; word-break: break-word; line-height: 1.2; max-width: 100%; overflow: hidden; }
  @media print {
    .back, .status, .lede, .controls, .err, .actions, header.site, footer.site, .oriz-sidebar { display: none !important; }
    .h1 { display: none; }
    .sheet { box-shadow: none; }
    .cell { outline: none; }
    @page { margin: 0.4in; }
  }
</style>

<script>
  // bwip-js — already a project dep, used for the QR rendering on a canvas.
  // @ts-ignore
  import bwipjs from 'bwip-js/browser';

  const colsEl = document.getElementById('cols') as HTMLInputElement;
  const rowsEl = document.getElementById('rows') as HTMLInputElement;
  const paperEl = document.getElementById('paper') as HTMLSelectElement;
  const captionEl = document.getElementById('caption') as HTMLInputElement;
  const repeatEl = document.getElementById('repeat') as HTMLInputElement;
  const srcEl = document.getElementById('src') as HTMLTextAreaElement;
  const sheet = document.getElementById('sheet') as HTMLElement;
  const err = document.getElementById('err') as HTMLElement;

  function parse(): {text:string; cap:string}[] {
    return srcEl.value
      .split(/\r?\n/)
      .map(l => l.trim())
      .filter(Boolean)
      .map(line => {
        const i = line.indexOf('|');
        return i >= 0 ? { text: line.slice(0,i).trim(), cap: line.slice(i+1).trim() }
                      : { text: line, cap: line };
      });
  }

  async function render() {
    err.hidden = true;
    try {
      const cols = Math.max(1, Math.min(10, parseInt(colsEl.value, 10) || 4));
      const rows = Math.max(1, Math.min(14, parseInt(rowsEl.value, 10) || 6));
      const cap = colsEl.value && rowsEl.value ? cols * rows : 0;
      const items = parse();
      if (!items.length) throw new Error('Enter at least one URL or label');

      const fill: typeof items = [];
      for (let i=0; i<cap; i++) {
        if (repeatEl.checked) fill.push(items[0]);
        else fill.push(items[i] || { text: '', cap: '' });
      }

      // Width in mm for paper
      const pageW = paperEl.value === 'A4' ? 210 : 215.9;
      const pageH = paperEl.value === 'A4' ? 297 : 279.4;
      const mmToPx = 96 / 25.4;
      sheet.style.width = (pageW * mmToPx) + 'px';
      sheet.style.height = (pageH * mmToPx) + 'px';
      sheet.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
      sheet.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
      sheet.innerHTML = '';

      for (const item of fill) {
        const div = document.createElement('div');
        div.className = 'cell';
        if (item.text) {
          const cnv = document.createElement('canvas');
          try {
            bwipjs.toCanvas(cnv, {
              bcid: 'qrcode',
              text: item.text,
              scale: 3,
              padding: 2,
            });
          } catch (e:any) {
            div.textContent = '?';
          }
          div.appendChild(cnv);
          if (captionEl.checked && item.cap) {
            const c = document.createElement('div');
            c.className = 'cap';
            c.textContent = item.cap;
            div.appendChild(c);
          }
        }
        sheet.appendChild(div);
      }
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
    }
  }

  document.getElementById('render')!.addEventListener('click', render);
  document.getElementById('print')!.addEventListener('click', () => { render(); setTimeout(() => window.print(), 100); });
  srcEl.value = 'https://oriz.in|oriz.in\nhttps://print.oriz.in|Print tools';
  render();
</script>
