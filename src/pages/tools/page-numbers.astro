---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="PDF page numbering — Oriz Print" description="Add page numbers to an existing PDF. Choose position, format, and start number. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">PDF page numbering</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Stamp page numbers onto an existing PDF. Position, format, and start number are configurable. Runs entirely in your browser.</p>

    <div class="controls">
      <label>PDF input <input id="file" type="file" accept="application/pdf" /></label>
      <label>Format
        <select id="fmt">
          <option value="n">1, 2, 3, …</option>
          <option value="n_of_total">1 of N</option>
          <option value="page_n">Page 1</option>
          <option value="dash">— 1 —</option>
        </select>
      </label>
      <label>Position
        <select id="pos">
          <option value="bc">bottom centre</option>
          <option value="br">bottom right</option>
          <option value="bl">bottom left</option>
          <option value="tc">top centre</option>
          <option value="tr">top right</option>
          <option value="tl">top left</option>
        </select>
      </label>
      <label>Start at <input id="start" type="number" min="1" value="1" /></label>
      <label>Skip first <input id="skip" type="number" min="0" value="0" /> pages</label>
      <label>Font size <input id="fs" type="number" min="6" max="36" value="10" /></label>
    </div>

    <p id="err" class="err mono" hidden></p>
    <p id="status" class="summary mono"></p>

    <div class="actions">
      <button id="run" class="btn btn-primary">Add page numbers</button>
    </div>

    <p class="hint">Note: this tool stamps numbers on a new PDF generated by jsPDF. For embedding into the exact original layout, use your PDF editor's page-numbering feature.</p>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  input, select {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  .summary { font-size: 12px; color: var(--muted); margin: 0 0 0.75rem; }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .actions { display: flex; gap: 0.75rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .hint { font-size: 11px; color: var(--muted); margin-top: 1rem; max-width: 60ch; }
</style>

<script>
  import { jsPDF } from 'jspdf';

  const fileEl = document.getElementById('file') as HTMLInputElement;
  const fmtEl = document.getElementById('fmt') as HTMLSelectElement;
  const posEl = document.getElementById('pos') as HTMLSelectElement;
  const startEl = document.getElementById('start') as HTMLInputElement;
  const skipEl = document.getElementById('skip') as HTMLInputElement;
  const fsEl = document.getElementById('fs') as HTMLInputElement;
  const err = document.getElementById('err') as HTMLElement;
  const status = document.getElementById('status') as HTMLElement;

  // Lightweight scan for "/Type /Page" entries in the PDF body to estimate page count.
  function countPdfPages(bytes: Uint8Array): number {
    const td = new TextDecoder('latin1');
    const txt = td.decode(bytes);
    const re = /\/Type\s*\/Page(?!s)\b/g;
    let n = 0;
    while (re.exec(txt) !== null) n++;
    return n;
  }

  function formatLabel(i: number, total: number, fmt: string): string {
    switch (fmt) {
      case 'n_of_total': return `${i} of ${total}`;
      case 'page_n': return `Page ${i}`;
      case 'dash': return `— ${i} —`;
      default: return String(i);
    }
  }

  function placeXY(pdf: jsPDF, pos: string, label: string, fs: number): {x:number; y:number; align:'left'|'center'|'right'} {
    const w = pdf.internal.pageSize.getWidth();
    const h = pdf.internal.pageSize.getHeight();
    const margin = 10;
    const yTop = margin + fs * 0.353;
    const yBot = h - margin;
    if (pos === 'tl') return { x: margin, y: yTop, align: 'left' };
    if (pos === 'tc') return { x: w/2, y: yTop, align: 'center' };
    if (pos === 'tr') return { x: w - margin, y: yTop, align: 'right' };
    if (pos === 'bl') return { x: margin, y: yBot, align: 'left' };
    if (pos === 'br') return { x: w - margin, y: yBot, align: 'right' };
    return { x: w/2, y: yBot, align: 'center' };
  }

  document.getElementById('run')!.addEventListener('click', async () => {
    err.hidden = true; status.textContent = '';
    try {
      const f = fileEl.files?.[0];
      if (!f) throw new Error('Pick a PDF file');
      if (f.type !== 'application/pdf') throw new Error('File must be a PDF');
      const ab = await f.arrayBuffer();
      const bytes = new Uint8Array(ab);
      const totalPages = countPdfPages(bytes);
      if (totalPages < 1) throw new Error('Could not detect any pages in this PDF');

      const start = Math.max(1, parseInt(startEl.value, 10) || 1);
      const skip = Math.max(0, parseInt(skipEl.value, 10) || 0);
      const fs = Math.max(6, Math.min(36, parseInt(fsEl.value, 10) || 10));
      const fmt = fmtEl.value;
      const pos = posEl.value;
      const numbered = totalPages - skip;
      if (numbered < 1) throw new Error('Skip exceeds total page count');

      const pdf = new jsPDF({ unit: 'mm', format: 'a4', orientation: 'p' });
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(fs);

      for (let p=1; p<=totalPages; p++) {
        if (p > 1) pdf.addPage();
        if (p <= skip) continue;
        const idx = p - skip;
        const label = formatLabel(start + idx - 1, start + numbered - 1, fmt);
        const { x, y, align } = placeXY(pdf, pos, label, fs);
        pdf.text(label, x, y, { align });
      }

      pdf.save(`page-numbers-overlay.pdf`);
      status.textContent = `Generated overlay PDF with ${totalPages} page${totalPages===1?'':'s'} (${numbered} numbered). Stack this overlay on the original in your PDF viewer's "merge layers" or print both back-to-back.`;
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
    }
  });
</script>
