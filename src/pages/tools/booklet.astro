---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Booklet imposition — Oriz Print" description="Reorder pages for saddle-stitch booklet printing. Enter your total page count and get the impose order. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Booklet imposition</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Reorder pages for saddle-stitch booklet printing. The tool computes the impose order for any page count, padded up to a multiple of four with blank pages.</p>

    <div class="controls">
      <label>Total pages <input id="count" type="number" min="1" max="500" value="12" /></label>
      <label>Sheet style
        <select id="style">
          <option value="duplex">Duplex (front + back per sheet)</option>
          <option value="simplex">Simplex (one side per sheet)</option>
        </select>
      </label>
    </div>

    <p id="err" class="err mono" hidden></p>
    <p id="summary" class="summary mono"></p>

    <div id="out" class="out" aria-live="polite"></div>

    <div class="actions">
      <button id="copy" class="btn">Copy order</button>
      <button id="print" class="btn btn-primary">Print order</button>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  input[type=number], select {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  .summary { font-size: 12px; color: var(--muted); margin: 0 0 0.75rem; }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .out { font-family: var(--font-mono); font-size: 0.875rem; color: var(--ink); }
  table { border-collapse: collapse; margin-bottom: 1rem; }
  th, td { border: 1px solid var(--rule); padding: 6px 10px; text-align: center; min-width: 3rem; }
  th { background: var(--paper-2); font-weight: 600; }
  .actions { display: flex; gap: 0.75rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn-primary:hover { opacity: 0.85; background: var(--accent); color: #fff; }
  @media print {
    .back, .status, .lede, .controls, .err, .actions, header.site, footer.site, .oriz-sidebar { display: none !important; }
  }
</style>

<script>
  const countEl = document.getElementById('count') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const out = document.getElementById('out') as HTMLElement;
  const summary = document.getElementById('summary') as HTMLElement;
  const err = document.getElementById('err') as HTMLElement;

  function impose(total: number) {
    const padded = Math.ceil(total / 4) * 4;
    const blanks = padded - total;
    const sheets: { sheet:number; frontL:number; frontR:number; backL:number; backR:number }[] = [];
    const sheetCount = padded / 4;
    for (let k=1; k<=sheetCount; k++) {
      sheets.push({
        sheet: k,
        frontL: padded - 2*k + 2,
        frontR: 2*k - 1,
        backL: 2*k,
        backR: padded - 2*k + 1,
      });
    }
    return { padded, blanks, sheets };
  }

  function render() {
    try {
      err.hidden = true;
      const n = parseInt(countEl.value, 10);
      if (!Number.isFinite(n) || n < 1 || n > 500) throw new Error('Enter a page count between 1 and 500');
      const duplex = styleEl.value === 'duplex';
      const { padded, blanks, sheets } = impose(n);
      summary.textContent = `${n} pages -> ${padded} positions (${blanks} blank), ${sheets.length} sheet${sheets.length===1?'':'s'}`;
      const lbl = (p: number) => p > n ? 'blank' : String(p);

      let html = '<table><thead><tr><th>Sheet</th><th>Front&nbsp;left</th><th>Front&nbsp;right</th><th>Back&nbsp;left</th><th>Back&nbsp;right</th></tr></thead><tbody>';
      for (const s of sheets) {
        html += `<tr><td>${s.sheet}</td><td>${lbl(s.frontL)}</td><td>${lbl(s.frontR)}</td><td>${lbl(s.backL)}</td><td>${lbl(s.backR)}</td></tr>`;
      }
      html += '</tbody></table>';

      if (!duplex) {
        const fronts: number[] = [];
        const backs: number[] = [];
        for (const s of sheets) fronts.push(s.frontL, s.frontR);
        for (const s of sheets) backs.push(s.backL, s.backR);
        html += '<p style="margin:0.5rem 0 0;color:var(--muted);font-size:12px">Simplex: print fronts first, then flip stack and print backs.</p>';
        html += '<p style="margin:0.25rem 0 0"><b>Fronts:</b> ' + fronts.map(lbl).join(' &middot; ') + '</p>';
        html += '<p style="margin:0.25rem 0 0"><b>Backs:</b> ' + backs.map(lbl).join(' &middot; ') + '</p>';
      }
      out.innerHTML = html;
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
      out.innerHTML = '';
      summary.textContent = '';
    }
  }

  document.getElementById('copy')!.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(out.innerText); } catch {}
  });
  document.getElementById('print')!.addEventListener('click', () => window.print());

  countEl.addEventListener('input', render);
  styleEl.addEventListener('change', render);
  render();
</script>
