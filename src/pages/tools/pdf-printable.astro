---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Text → printable PDF — Oriz Print" description="Convert pasted text or Markdown-lite to a clean printable PDF. Choose paper, margins, and font size. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Text → printable PDF</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Paste plain text (or markdown-lite — # headings and blank-line paragraphs) and download a clean, print-ready PDF. Everything runs in your browser.</p>

    <div class="controls">
      <label>Paper
        <select id="paper">
          <option value="a4">A4</option>
          <option value="letter">Letter</option>
        </select>
      </label>
      <label>Orientation
        <select id="orient">
          <option value="p">Portrait</option>
          <option value="l">Landscape</option>
        </select>
      </label>
      <label>Margin (mm) <input id="margin" type="number" min="0" max="40" value="20" /></label>
      <label>Font size <input id="fs" type="number" min="8" max="24" value="11" /></label>
      <label>Line spacing <input id="ls" type="number" min="1" max="2.5" step="0.05" value="1.4" /></label>
      <label>Title <input id="title" type="text" value="Untitled" style="min-width:14rem" /></label>
    </div>

    <label class="block">Text
      <textarea id="src" rows="12" placeholder="# My document&#10;&#10;First paragraph of text…&#10;&#10;Another paragraph."></textarea>
    </label>

    <p id="err" class="err mono" hidden></p>

    <div class="actions">
      <button id="run" class="btn btn-primary">Download PDF</button>
      <button id="print" class="btn">Print preview</button>
    </div>

    <div id="preview" class="preview" aria-live="polite"></div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  label.block { display: block; margin-bottom: 1rem; }
  input, select, textarea {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  textarea { width: 100%; resize: vertical; font-family: var(--font-mono); }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .actions { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .preview { background: #fff; color: #15140f; border: 1px solid var(--rule); padding: 1.5rem; font-family: Inter, system-ui, sans-serif; max-width: 60ch; min-height: 4rem; }
  .preview h1, .preview h2, .preview h3 { font-family: 'Fraunces', Crimson Pro, serif; }
  .preview h1 { font-size: 1.5rem; margin: 0 0 0.5rem; }
  .preview h2 { font-size: 1.2rem; margin: 1rem 0 0.4rem; }
  .preview h3 { font-size: 1rem; margin: 0.8rem 0 0.3rem; }
  .preview p { margin: 0 0 0.6rem; line-height: 1.55; }
  @media print {
    .back, .status, .lede, .controls, .err, .actions, header.site, footer.site, .oriz-sidebar, label.block { display: none !important; }
    .h1 { display: none; }
    .preview { border: none; padding: 0; max-width: none; }
  }
</style>

<script>
  import { jsPDF } from 'jspdf';

  const paperEl = document.getElementById('paper') as HTMLSelectElement;
  const orientEl = document.getElementById('orient') as HTMLSelectElement;
  const marginEl = document.getElementById('margin') as HTMLInputElement;
  const fsEl = document.getElementById('fs') as HTMLInputElement;
  const lsEl = document.getElementById('ls') as HTMLInputElement;
  const titleEl = document.getElementById('title') as HTMLInputElement;
  const srcEl = document.getElementById('src') as HTMLTextAreaElement;
  const err = document.getElementById('err') as HTMLElement;
  const preview = document.getElementById('preview') as HTMLElement;

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c] as string));
  }

  type Block = { type: 'h1'|'h2'|'h3'|'p'; text: string };
  function parseBlocks(text: string): Block[] {
    const out: Block[] = [];
    const paras = text.split(/\n\s*\n/);
    for (const p of paras) {
      const trimmed = p.trim();
      if (!trimmed) continue;
      if (trimmed.startsWith('### ')) out.push({ type:'h3', text: trimmed.slice(4) });
      else if (trimmed.startsWith('## ')) out.push({ type:'h2', text: trimmed.slice(3) });
      else if (trimmed.startsWith('# ')) out.push({ type:'h1', text: trimmed.slice(2) });
      else out.push({ type:'p', text: trimmed.replace(/\n/g, ' ') });
    }
    return out;
  }

  function renderPreview() {
    const blocks = parseBlocks(srcEl.value);
    preview.innerHTML = blocks.map(b => {
      const tag = b.type;
      return `<${tag}>${escapeHtml(b.text)}</${tag}>`;
    }).join('') || '<p style="color:#999">Type or paste text to preview…</p>';
  }

  function buildPdf(): jsPDF {
    const margin = Math.max(0, parseFloat(marginEl.value) || 20);
    const fs = Math.max(8, Math.min(24, parseInt(fsEl.value, 10) || 11));
    const ls = Math.max(1, parseFloat(lsEl.value) || 1.4);
    const pdf = new jsPDF({ unit: 'mm', format: paperEl.value, orientation: orientEl.value as 'p'|'l' });
    const pageW = pdf.internal.pageSize.getWidth();
    const pageH = pdf.internal.pageSize.getHeight();
    const innerW = pageW - margin*2;
    let y = margin;
    const lineH = fs * 0.353 * ls;

    function ensureRoom(h: number) {
      if (y + h > pageH - margin) {
        pdf.addPage();
        y = margin;
      }
    }

    pdf.setFont('helvetica', 'bold');
    pdf.setFontSize(fs + 6);
    const title = titleEl.value.trim() || 'Untitled';
    const titleLines = pdf.splitTextToSize(title, innerW);
    for (const l of titleLines) {
      ensureRoom(lineH*1.4);
      pdf.text(l, margin, y + (fs+6)*0.353);
      y += (fs+6)*0.353*ls;
    }
    y += lineH*0.5;

    const blocks = parseBlocks(srcEl.value);
    for (const b of blocks) {
      if (b.type === 'h1') { pdf.setFont('helvetica','bold'); pdf.setFontSize(fs+5); }
      else if (b.type === 'h2') { pdf.setFont('helvetica','bold'); pdf.setFontSize(fs+3); }
      else if (b.type === 'h3') { pdf.setFont('helvetica','bold'); pdf.setFontSize(fs+1); }
      else { pdf.setFont('helvetica','normal'); pdf.setFontSize(fs); }
      const fsUsed = (pdf as any).internal.getFontSize();
      const lh = fsUsed * 0.353 * ls;
      const lines = pdf.splitTextToSize(b.text, innerW);
      if (b.type !== 'p') y += lh*0.3;
      for (const l of lines) {
        ensureRoom(lh);
        pdf.text(l, margin, y + fsUsed*0.353);
        y += lh;
      }
      y += lh*0.3;
    }
    return pdf;
  }

  document.getElementById('run')!.addEventListener('click', () => {
    err.hidden = true;
    try {
      const pdf = buildPdf();
      pdf.save(`${(titleEl.value.trim()||'document').replace(/[^\w\-]+/g,'_')}.pdf`);
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
    }
  });
  document.getElementById('print')!.addEventListener('click', () => window.print());

  srcEl.addEventListener('input', renderPreview);
  titleEl.addEventListener('input', renderPreview);
  if (!srcEl.value) srcEl.value = '# My document\n\nFirst paragraph of text.\n\n## Section\n\nAnother paragraph here.';
  renderPreview();
</script>
