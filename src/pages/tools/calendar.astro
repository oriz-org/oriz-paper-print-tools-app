---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Printable calendar — Oriz Print" description="Generate a clean printable monthly or yearly calendar. Pick a year and month, print on letter or A4. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Printable calendar</h1>
    <p class="status mono ready">ready</p>
    <p class="lede">Pick a year and month (or a full year) and print a clean calendar. Choose Monday or Sunday start, ISO week numbers optional.</p>

    <div class="controls">
      <label>Year <input id="year" type="number" min="1900" max="2100" /></label>
      <label>Month
        <select id="month">
          <option value="-1">Full year (12 months)</option>
          <option value="0">January</option><option value="1">February</option>
          <option value="2">March</option><option value="3">April</option>
          <option value="4">May</option><option value="5">June</option>
          <option value="6">July</option><option value="7">August</option>
          <option value="8">September</option><option value="9">October</option>
          <option value="10">November</option><option value="11">December</option>
        </select>
      </label>
      <label>Week starts
        <select id="start">
          <option value="1">Monday</option>
          <option value="0">Sunday</option>
        </select>
      </label>
      <label class="chk"><input id="weeks" type="checkbox" /> show ISO week numbers</label>
    </div>

    <p id="err" class="err mono" hidden></p>

    <div class="actions">
      <button id="print" class="btn btn-primary">Print</button>
    </div>

    <div id="out" class="out" aria-live="polite"></div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 1.5rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin-bottom: 1rem; }
  label { font-size: 0.875rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.2rem; }
  label.chk { flex-direction: row; align-items: center; gap: 0.4rem; }
  input[type=number], select {
    padding: 0.4rem 0.6rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem;
  }
  .err { color: #b00020; font-size: 12px; margin: 0 0 0.75rem; }
  .actions { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; }
  .btn { padding: 0.4rem 0.9rem; border: 1px solid var(--rule); background: var(--paper-2);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { background: var(--ink); color: var(--paper); }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .out { background: #fff; padding: 1rem; border: 1px solid var(--rule); color: #15140f; }
  .cal-month { margin-bottom: 1rem; page-break-inside: avoid; break-inside: avoid; }
  .cal-month h2 { font-family: var(--font-display); font-weight: 600; font-size: 1.25rem; margin: 0 0 0.5rem; color: var(--accent); }
  table.cal { border-collapse: collapse; width: 100%; font-family: Inter, system-ui, sans-serif; }
  table.cal th, table.cal td { border: 1px solid #ddd; padding: 6px 4px; text-align: right; vertical-align: top; width: 14%; height: 40px; font-size: 0.85rem; }
  table.cal th { background: #faf6ef; font-weight: 600; text-align: center; font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase; color: #555; }
  table.cal td.dim { color: #bbb; }
  table.cal td.wk { background: #fafafa; color: #888; font-size: 0.7rem; text-align: center; }
  .year-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .year-grid table.cal th, .year-grid table.cal td { height: 28px; font-size: 0.7rem; padding: 3px 3px; }
  .year-grid .cal-month h2 { font-size: 0.95rem; }
  @media print {
    .back, .status, .lede, .controls, .err, .actions, header.site, footer.site, .oriz-sidebar { display: none !important; }
    .h1 { font-size: 1.4rem; margin-bottom: 0.5rem; }
    .out { border: none; padding: 0; }
    @page { margin: 0.5in; }
  }
</style>

<script>
  const NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const yearEl = document.getElementById('year') as HTMLInputElement;
  const monthEl = document.getElementById('month') as HTMLSelectElement;
  const startEl = document.getElementById('start') as HTMLSelectElement;
  const weeksEl = document.getElementById('weeks') as HTMLInputElement;
  const out = document.getElementById('out') as HTMLElement;
  const err = document.getElementById('err') as HTMLElement;

  function isoWeek(d: Date): number {
    const t = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
    t.setUTCDate(t.getUTCDate() + 4 - (t.getUTCDay() || 7));
    const yearStart = new Date(Date.UTC(t.getUTCFullYear(), 0, 1));
    return Math.ceil((((t.getTime() - yearStart.getTime()) / 86400000) + 1) / 7);
  }

  function monthHtml(year: number, month: number, weekStart: number, showWeeks: boolean): string {
    const first = new Date(year, month, 1);
    const daysInMonth = new Date(year, month+1, 0).getDate();
    const firstDow = first.getDay();
    let offset = (firstDow - weekStart + 7) % 7;

    let dayLabels: string[] = [];
    const base = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    for (let i=0; i<7; i++) dayLabels.push(base[(weekStart + i) % 7]);

    let html = `<div class="cal-month"><h2>${NAMES[month]} ${year}</h2><table class="cal"><thead><tr>`;
    if (showWeeks) html += '<th>Wk</th>';
    for (const d of dayLabels) html += `<th>${d}</th>`;
    html += '</tr></thead><tbody>';

    let day = 1;
    const prevMonthDays = new Date(year, month, 0).getDate();
    for (let week=0; week<6; week++) {
      if (day > daysInMonth) break;
      const rowDate = new Date(year, month, Math.min(day, daysInMonth));
      html += '<tr>';
      if (showWeeks) {
        const seedDay = day > daysInMonth ? daysInMonth : day;
        html += `<td class="wk">${isoWeek(new Date(year, month, seedDay))}</td>`;
      }
      for (let dow=0; dow<7; dow++) {
        const cellIndex = week*7 + dow;
        if (cellIndex < offset) {
          html += `<td class="dim">${prevMonthDays - offset + cellIndex + 1}</td>`;
        } else if (day > daysInMonth) {
          html += `<td class="dim">${day - daysInMonth}</td>`;
          day++;
        } else {
          html += `<td>${day}</td>`;
          day++;
        }
      }
      html += '</tr>';
    }
    html += '</tbody></table></div>';
    return html;
  }

  function render() {
    try {
      err.hidden = true;
      const y = parseInt(yearEl.value, 10);
      if (!Number.isFinite(y) || y < 1900 || y > 2100) throw new Error('Enter a year between 1900 and 2100');
      const m = parseInt(monthEl.value, 10);
      const ws = parseInt(startEl.value, 10);
      const showWeeks = weeksEl.checked;
      if (m === -1) {
        let html = '<div class="year-grid">';
        for (let i=0; i<12; i++) html += monthHtml(y, i, ws, showWeeks);
        html += '</div>';
        out.innerHTML = html;
      } else {
        out.innerHTML = monthHtml(y, m, ws, showWeeks);
      }
    } catch (e:any) {
      err.hidden = false;
      err.textContent = 'Error: ' + (e?.message || String(e));
      out.innerHTML = '';
    }
  }

  const now = new Date();
  yearEl.value = String(now.getFullYear());
  monthEl.value = String(now.getMonth());
  yearEl.addEventListener('input', render);
  monthEl.addEventListener('change', render);
  startEl.addEventListener('change', render);
  weeksEl.addEventListener('change', render);
  document.getElementById('print')!.addEventListener('click', () => window.print());
  render();
</script>
