---
import '~/styles/global.css'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Print — Paper-first. Booklets, n-up, labels, grids.', description = 'Print preview, booklet layout, n-up, page numbering, Avery labels, QR sticker sheets, graph paper.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://print.oriz.in').toString()
const pricingHref = pricingUrl('oriz-paper-print-tools-app')
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Print</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingHref}>pricing</a>
        <a href="https://account.oriz.in/sign-in">sign in</a>
      </nav>
    </header>
    <main id="main">
      <div class="oriz-shell">
        <FamilySidebar slug="oriz-paper-print-tools-app" title="Print Tools">
          <a slot="tools" href="/tools/avery/">Avery labels</a>
          <a slot="tools" href="/tools/booklet/">Booklet imposition</a>
          <a slot="tools" href="/tools/business-card/">Business cards</a>
          <a slot="tools" href="/tools/calendar/">Calendar</a>
          <a slot="tools" href="/tools/checklist/">Checklist</a>
          <a slot="tools" href="/tools/graph-paper/">Graph paper</a>
          <a slot="tools" href="/tools/label-maker/">Label maker</a>
          <a slot="tools" href="/tools/n-up/">N-up</a>
          <a slot="tools" href="/tools/page-numbers/">Page numbers</a>
          <a slot="tools" href="/tools/pdf-printable/">PDF printable</a>
          <a slot="tools" href="/tools/preview/">Print preview</a>
          <a slot="tools" href="/tools/qr-stickers/">QR stickers</a>
        </FamilySidebar>
        <main class="oriz-main"><slot /></main>
      </div>
    </main>
    <footer class="site">
      <span>Oriz Print · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>

<style is:global>
  nav a { min-height: 32px; padding: 6px 0; display: inline-flex; align-items: center; }
</style>
